---
/**
 * Contact — the camp mailbox. A mailto link is enough for the MVP.
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import PageTitle from '../components/sections/PageTitle.astro';
import Icon from '../components/decor/Icon.astro';
import { routes } from '../lib/i18n';

const topics = [
  'Camp Flaneuse itself — questions, hellos, bird reports',
  'Correspondence — letters, replies, future snail mail',
  'The Soft Footsteps Society — early interest in enrollment',
  'Flaneuse Studio — website projects, big or tiny',
  'Collaborations and other kind schemes',
];
---

<BaseLayout
  title="Contact"
  description="Write to Camp Flaneuse — about the camp, the letters, the Soft Footsteps Society, or a website project for Flaneuse Studio."
  lang="en"
  translationUrl={routes.contact.pt}
>
  <PageTitle
    overline="The mailbox"
    title="Write to the camp"
    lede="The camp receives visitors and letters. Both are answered — slowly, sincerely, in order of arrival, weather permitting."
  />

  <section class="section contact-body">
    <div class="container">
      <div class="prose">
        <p>You are welcome to write about:</p>
        <ul>
          {topics.map((topic) => <li>{topic}</li>)}
        </ul>
        <p>
          There is no form, no chatbot, and no funnel. There will be an email address — a real
          one — as soon as the camp finishes installing its mailbox:
        </p>
      </div>

      <div class="mailbox-closed panel">
        <span class="mailbox-icon"><Icon name="envelope" size={26} /></span>
        <p class="mailbox-line">The mailbox is not open yet.</p>
        <p class="email-note label">
          (A real address arrives together with the camp's own domain. Until then, nothing you
          send can get lost, because nothing can be sent.)
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .mailbox-closed {
    margin-top: 2rem;
    max-width: 30rem;
    padding: 1.6rem 1.8rem;
    border-style: dashed;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mailbox-icon {
    display: inline-flex;
    color: var(--color-clay);
  }

  .mailbox-line {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
  }

  .email-note {
    color: var(--color-ink-faint);
  }
</style>
