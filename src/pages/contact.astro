---
/**
 * Contact — the camp mailbox, organized into clear destinations.
 * Addresses come from the central data in lib/contact.ts; the
 * visible copy lives here (page copy stays in the page).
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import PageTitle from '../components/sections/PageTitle.astro';
import Icon, { type IconName } from '../components/decor/Icon.astro';
import { routes } from '../lib/i18n';
import { contactAddresses, mailtoLink } from '../lib/contact';

const desks: {
  key: 'general' | 'correspondence' | 'studio';
  icon: IconName;
  color: string;
  name: string;
  description: string;
}[] = [
  {
    key: 'general',
    icon: 'tent',
    color: 'var(--color-clay)',
    name: 'Write to the camp',
    description: 'For general messages, questions, and notes sent toward Camp Flaneuse.',
  },
  {
    key: 'correspondence',
    icon: 'envelope',
    color: 'var(--color-river)',
    name: 'Correspondence Desk',
    description: 'For letters, observations, findings, and replies intended for the Soft Footsteps Society.',
  },
  {
    key: 'studio',
    icon: 'brush',
    color: 'var(--color-olive)',
    name: 'Flaneuse Studio',
    description: 'For commissions, collaborations, and websites for artists.',
  },
];
---

<BaseLayout
  title="Contact"
  description="Write to Camp Flaneuse — the camp, the Soft Footsteps Society's Correspondence Desk, or Flaneuse Studio for commissions and collaborations."
  lang="en"
  translationUrl={routes.contact.pt}
>
  <PageTitle
    overline="The mailbox"
    title="Write to the camp"
    lede="The camp receives visitors and letters. Both are welcomed. Letters are answered slowly, sincerely, and in order of arrival, weather permitting."
  />

  <section class="section contact-body">
    <div class="container">
      <p class="prose desks-intro">
        There is no form, no chatbot, and no funnel. There are a few desks, each with its own
        address:
      </p>

      <div class="desks">
        {
          desks.map((desk) => (
            <div class="desk panel" style={`--desk-color: ${desk.color}`}>
              <span class="desk-icon">
                <Icon name={desk.icon} size={22} />
              </span>
              <p class="desk-name">{desk.name}</p>
              <p class="desk-description">{desk.description}</p>
              <a class="desk-email" href={mailtoLink(desk.key, 'en')}>
                {contactAddresses[desk.key].email}
              </a>

              {desk.key === 'correspondence' && (
                <p class="desk-aside">
                  <span class="desk-aside-icon"><Icon name="notebook" size={15} /></span>
                  Professor Emberroot also keeps an address, for the Society's stranger business:
                  <br />
                  <a href={mailtoLink('professor', 'en')}>{contactAddresses.professor.email}</a>
                </p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section contact-notes-section">
    <div class="container">
      <div class="contact-notes">
        <section class="contact-note">
          <h2 class="contact-note-heading">Not sure where your letter belongs?</h2>
          <p>
            Send it to <a href={mailtoLink('general', 'en')}>{contactAddresses.general.email}</a>.
            The camp will carry it to the appropriate desk, with varying degrees of administrative
            competence.
          </p>
          <p>
            Messages are read by Elai. Replies may take a little while during road days, difficult
            weather, cat emergencies, or periods of excessive attention to birds.
          </p>
        </section>

        <section class="contact-note">
          <h2 class="contact-note-heading">Looking to receive letters?</h2>
          <p>
            The Correspondence Desk sends stories, drawings, field notes, maps, misplaced
            creatures, and reports from Camp Flaneuse.
          </p>
          <p class="contact-note-cta">
            <a href={`${routes.softFootsteps.en}#newsletter`}>
              Receive correspondence from the Soft Footsteps Society →
            </a>
          </p>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>


<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .desks-intro {
    color: var(--color-ink-soft);
  }

  .desks {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.1rem;
    max-width: 64rem;
  }

  .desk {
    padding: 1.5rem 1.6rem;
    border-top: 3px solid var(--desk-color);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .desk-icon {
    display: inline-flex;
    color: var(--desk-color);
    margin-bottom: 0.2rem;
  }

  .desk-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .desk-description {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-email {
    margin-top: 0.4rem;
    font-family: var(--font-label);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  /* Professor Emberroot: a smaller related contact under the Desk. */
  .desk-aside {
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px dashed var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-aside-icon {
    display: inline-flex;
    vertical-align: -2px;
    margin-right: 0.3rem;
    color: var(--color-ink-faint);
  }

  .desk-aside a {
    overflow-wrap: anywhere;
    word-break: normal;
  }

  /* The notes sit in their own soft band, like the homepage's
     alternating sections. As the last band it grows to meet the
     footer (no paper strip beneath), with extra bottom room so the
     content never crowds the footer. */
  .contact-notes-section {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-top: 1px solid var(--color-line-soft);
    flex: 1;
    padding-bottom: calc(var(--space-section) + 1.5rem);
  }

  /* Two quiet practical notes below the desks — not competing cards. */
  .contact-notes {
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-block);
  }

  .contact-note-heading {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .contact-note p {
    color: var(--color-ink-soft);
  }

  .contact-note p + p {
    margin-top: 0.7rem;
  }

  .contact-note-cta {
    margin-top: 0.9rem;
    font-weight: 700;
  }

  .contact-note-cta a {
    color: var(--color-clay-deep);
  }
</style>

<style is:global>
  /* Contact page only: let <main> distribute height so the final band
     fills down to the footer, and drop the footer's usual top gap so
     the band meets it flush (no mismatched paper strip). */
  main:has(.contact-notes-section) {
    display: flex;
    flex-direction: column;
  }

  body:has(.contact-notes-section) .site-footer {
    margin-top: 0;
  }
</style>
