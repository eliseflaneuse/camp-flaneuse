---
/**
 * Contact — the camp mailbox, now genuinely open. Three desks,
 * three addresses: mailto links are enough for the MVP.
 */
import BaseLayout from '../components/layout/BaseLayout.astro';
import PageTitle from '../components/sections/PageTitle.astro';
import Icon, { type IconName } from '../components/decor/Icon.astro';
import { routes } from '../lib/i18n';

const desks: { icon: IconName; color: string; name: string; description: string; email: string }[] = [
  {
    icon: 'tent',
    color: 'var(--color-clay)',
    name: 'Camp Flaneuse',
    description: 'Questions, hellos, bird reports, and collaborations or other kind schemes.',
    email: 'hello@campflaneuse.com',
  },
  {
    icon: 'envelope',
    color: 'var(--color-river)',
    name: 'The Correspondence Desk',
    description: 'Letters, replies, and early interest in the Soft Footsteps Society.',
    email: 'correspondence@campflaneuse.com',
  },
  {
    icon: 'brush',
    color: 'var(--color-olive)',
    name: 'Flaneuse Studio',
    description: 'Website projects, big or tiny.',
    email: 'studio@campflaneuse.com',
  },
];
---

<BaseLayout
  title="Contact"
  description="Write to Camp Flaneuse — about the camp, the letters, the Soft Footsteps Society, or a website project for Flaneuse Studio."
  lang="en"
  translationUrl={routes.contact.pt}
>
  <PageTitle
    overline="The mailbox"
    title="Write to the camp"
    lede="The camp receives visitors and letters. Both are answered — slowly, sincerely, in order of arrival, weather permitting."
  />

  <section class="section contact-body">
    <div class="container">
      <p class="prose desks-intro">
        There is no form, no chatbot, and no funnel. There are three desks, each with its own
        address:
      </p>

      <div class="desks">
        {
          desks.map((desk) => (
            <div class="desk panel" style={`--desk-color: ${desk.color}`}>
              <span class="desk-icon">
                <Icon name={desk.icon} size={22} />
              </span>
              <p class="desk-name">{desk.name}</p>
              <p class="desk-description">{desk.description}</p>
              <a class="desk-email" href={`mailto:${desk.email}`}>{desk.email}</a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .desks-intro {
    color: var(--color-ink-soft);
  }

  .desks {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.1rem;
    max-width: 52rem;
  }

  .desk {
    padding: 1.5rem 1.6rem;
    border-top: 3px solid var(--desk-color);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .desk-icon {
    display: inline-flex;
    color: var(--desk-color);
    margin-bottom: 0.2rem;
  }

  .desk-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .desk-description {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-email {
    margin-top: 0.4rem;
    font-family: var(--font-label);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    word-break: break-all;
  }
</style>
