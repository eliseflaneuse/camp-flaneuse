---
/**
 * Flaneuse Studio — a oficina, em português.
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import StudioPackageCard from '../../components/sections/StudioPackageCard.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { routes } from '../../lib/i18n';

const whoFor = [
  'Artistas que precisam de um portfólio que pareça com a obra, não com um template vestindo a obra',
  'Quem escreve e precisa de uma casa para as palavras',
  'Quem faz coisas com as mãos e quer uma presença simples agora, e talvez uma lojinha depois',
  'Terapeutas e profissionais independentes que precisam de um site calmo e humano',
  'Gente criativa em pequena escala, alérgica a templates corporativos',
  'Pessoas com ideias demais, que precisam mais de estrutura do que de funcionalidades',
];

const services = [
  'Sites de uma página',
  'Sites de portfólio',
  'Blogs e diários simples',
  'Estrutura e texto — para quem (ainda) não consegue se explicar online',
  'Direção visual',
  'Redesenhos gentis de sites existentes',
  'Arquivos criativos pessoais',
  'Pequenas páginas de lançamento',
];

const labels = { bestFor: 'Bom para', includes: 'Inclui' };

const packages = [
  {
    name: 'O Quarto Pequeno',
    summary: 'Um site de uma página para uma pessoa, projeto ou oferta. Tudo o que é essencial, nada gritando.',
    bestFor: 'Artistas, gente criativa e negócios minúsculos começando agora.',
    includes: [
      'Uma página estruturada com cuidado',
      'Ajuda com o texto — suas palavras, arrumadas',
      'Direção visual alinhada com o seu trabalho',
      'Rápido, acessível, bom no celular',
    ],
    priceNote: 'Preço sob consulta — valores de começo de estrada',
    labels,
  },
  {
    name: 'O Arquivo de Campo',
    summary: 'Um site simples de várias páginas: portfólio, diário, sobre, contato. Um lugar para o trabalho se acumular.',
    bestFor: 'Artistas, quem escreve, e pessoas com uma obra em andamento.',
    includes: [
      'Até cinco páginas, claramente estruturadas',
      'Um diário ou portfólio que você atualiza por conta própria',
      'Orientação de texto e estrutura',
      'Espaço para crescer — sem precisar reconstruir depois',
    ],
    priceNote: 'Preço sob consulta — valores de começo de estrada',
    labels,
  },
  {
    name: 'O Lançamento Suave',
    summary: 'Uma página focada para uma coisa só: um curso, um projeto, uma newsletter, um serviço, uma ideia pronta para conhecer pessoas.',
    bestFor: 'Quem está lançando algo específico e sincero.',
    includes: [
      'Uma página focada, persuasiva mas honesta',
      'Estrutura clara: o que é, para quem é, o que fazer em seguida',
      'Afiação do texto',
      'Configuração técnica simples e confiável',
    ],
    priceNote: 'Preço sob consulta — valores de começo de estrada',
    labels,
  },
];
---

<BaseLayout
  title="Flaneuse Studio"
  description="O Flaneuse Studio faz sites pequenos e cuidadosos para artistas, terapeutas, profissionais independentes e quem escreve ou cria. Não sites que gritam — sites que reúnem, clarificam e dão ao seu trabalho um lugar para morar."
  lang="pt"
  translationUrl={routes.studio.en}
>
  <PageTitle
    overline="A oficina"
    title="Flaneuse Studio"
    lede="Sites pequenos com alma — poéticos, práticos, feitos para quem constrói uma vida ou uma prática fora do template."
  />

  <section class="section">
    <div class="container">
      <div class="prose">
        <p>
          O Flaneuse Studio faz sites pequenos e cuidadosos para artistas, terapeutas,
          profissionais independentes e quem escreve ou cria. Não sites que gritam. Sites que reúnem,
          clarificam e dão ao seu trabalho um lugar para morar.
        </p>
        <p>
          O estúdio fica nos fundos do Camp Flaneuse, o que significa que ele é pequeno de
          propósito, trabalha devagar e com cuidado, e acredita que um site deve parecer menos com
          um cartão de visitas e mais com um cômodo em que alguém pode entrar.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro overline="Para quem é" title="Pessoas construindo algo terno, estranho, útil ou verdadeiro." />
      <ul class="two-col-list">
        {whoFor.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro overline="O que o estúdio faz" title="Com o que eu posso ajudar" />
      <ul class="two-col-list">
        {services.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro
        overline="Jeitos de trabalhar lado a lado"
        title="Três cômodos, três tamanhos"
        lede="Estes são formatos de partida, não caixas rígidas. Cada projeto é ajustado para caber a pessoa que mora dentro dele."
      />
      <div class="packages-grid">
        {packages.map((pkg) => <StudioPackageCard {...pkg} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        overline="Por que este estúdio existe"
        title="A maioria de quem cria não precisa de um site barulhento."
        lede="Precisa de um lugar com a sua cara, que explique o trabalho com clareza e possa crescer devagar. Estrutura clara, design gentil, texto humano, configuração técnica simples, espaço para crescer — essa é a filosofia inteira, e por incrível que pareça, ela é rara."
      />
    </div>
  </section>

  <CTASection
    overline="Comece por aqui"
    title="Me conte sobre o seu projeto."
    text="Algumas frases bastam. O que você faz, para o que você precisa de uma casa, e com o que deve parecer entrar nela."
    cta={{ label: 'Escrever para o estúdio', href: routes.contact.pt }}
  />
</BaseLayout>

<style>
  .section--deep {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-block: 1px solid var(--color-line-soft);
  }

  .two-col-list {
    max-width: 52rem;
    columns: 2;
    column-gap: 3rem;
    padding-left: 1.2rem;
    color: var(--color-ink-soft);
  }

  .two-col-list li {
    margin-bottom: 0.7rem;
    break-inside: avoid;
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.2rem;
  }

  @media (max-width: 640px) {
    .two-col-list {
      columns: 1;
    }
  }
</style>
