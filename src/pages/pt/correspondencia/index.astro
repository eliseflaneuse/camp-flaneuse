---
/**
 * Correspondência — a gaveta de cartas, em português.
 */
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PageTitle from '../../../components/sections/PageTitle.astro';
import LetterCard from '../../../components/content/LetterCard.astro';
import { routes } from '../../../lib/i18n';
import { getLetters } from '../../../lib/content';

const letters = await getLetters('pt');
---

<BaseLayout
  title="Correspondência"
  description="Cartas da estrada: convites, notas sazonais e futuras peças de correio de papel do Camp Flaneuse."
  lang="pt"
  translationUrl={routes.correspondence.en}
>
  <PageTitle
    overline="A escrivaninha"
    title="Correspondência"
    lede="Algumas notas não são posts. Algumas coisas chegam melhor como cartas — mais devagar, mais baixinho, endereçadas a você."
  />

  <section class="section letters-section">
    <div class="container">
      <p class="letters-intro">
        Estas são cartas da estrada: convites, despachos sazonais, pequenas confissões e — um dia —
        peças que vão viajar pelo correio de verdade, com selo e tudo. A gaveta está quase vazia
        por enquanto. É assim que as gavetas começam.
      </p>

      <div class="letters-grid">
        {letters.map((letter) => <LetterCard letter={letter} lang="pt" />)}
      </div>

      <aside class="society-hint panel">
        <p class="label society-hint-label">Um anúncio em voz baixa</p>
        <p>
          Algumas destas cartas serão um dia enviadas pela
          <strong>Sociedade dos Passos Suaves</strong> — uma pequena sociedade para quem caminha
          com atenção, atualmente em fundação nesta mesma escrivaninha.
        </p>
        <p class="society-hint-link">
          <a href={routes.softFootsteps.pt}>Conhecer a Sociedade →</a>
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .letters-section {
    padding-block: var(--space-block) var(--space-section);
  }

  .letters-intro {
    max-width: var(--prose-width);
    color: var(--color-ink-soft);
    margin-bottom: var(--space-block);
  }

  .letters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: 1.2rem;
    max-width: 44rem;
  }

  .society-hint {
    margin-top: var(--space-block);
    max-width: var(--prose-width);
    padding: 1.5rem 1.7rem;
    border-left: 4px solid var(--color-river);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .society-hint-label {
    color: var(--color-river);
  }

  .society-hint-link {
    font-weight: 700;
  }
</style>
