---
/**
 * Sociedade dos Passos Suaves — a sala das cartas do acampamento.
 */
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PageTitle from '../../../components/sections/PageTitle.astro';
import SectionIntro from '../../../components/sections/SectionIntro.astro';
import LetterCard from '../../../components/content/LetterCard.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import NewsletterSignup from '../../../components/sections/NewsletterSignup.astro';
import { routes } from '../../../lib/i18n';
import { mailtoLink } from '../../../lib/contact';
import { getLetters } from '../../../lib/content';

const letters = await getLetters('pt');

const futureDispatches = [
  'Cartas da estrada',
  'Pequenos desenhos',
  'Histórias de fantasma e outros anexos',
  'Tarefas de campo para gente atenta',
  'Despachos sazonais',
  'Cartões-postais, ocasionalmente urgentes',
  'Relatos sobre pássaros, tempo, criaturas e outras evidências difíceis',
];
---

<BaseLayout
  title="Sociedade dos Passos Suaves"
  description="Uma sociedade pequena e pouco organizada para quem caminha com atenção, observa devagar, guarda cartas e repara em criaturas. Casa da Mesa de Correspondência e das cartas da estrada."
  lang="pt"
  translationUrl={routes.softFootsteps.en}
>
  <PageTitle
    overline="The Soft Footsteps Society"
    title="Sociedade dos Passos Suaves"
    lede="Uma sociedade pequena e pouco organizada para quem caminha com atenção, observa devagar, guarda cartas, repara em criaturas e tenta atravessar o mundo sem fazer tanto barulho."
  />

  <section class="section society-intro">
    <div class="container">
      <div class="prose">
        <p>
          A Sociedade reúne pessoas que reparam, colecionam, lembram e, de vez em quando, enviam
          umas às outras provas de que o mundo ainda é estranho, vivo e capaz de responder.
        </p>
        <p>Algumas observações pertencem às Notas de Campo.</p>
        <p>Outras precisam de um envelope.</p>
        <p>
          A Sociedade mantém atualmente sua Mesa de Correspondência no Camp Flaneuse, um
          acampamento em movimento de onde cartas, desenhos, histórias, tarefas de campo e outras
          evidências gentis são enviadas ao mundo.
        </p>
        <p>
          Não há sede fixa. A geografia é flexível. Fazer parte começa quando alguém repara em
          alguma coisa e se recusa a passar por ela com pressa.
        </p>
        <p>A Sociedade ainda está tomando forma, mas já não é apenas teórica.</p>
        <p>A primeira carta já saiu da mesa.</p>
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro overline="A sala dentro da sala" title="A Mesa de Correspondência" />
      <div class="prose">
        <p>
          A Mesa de Correspondência é a parte da Sociedade responsável por garantir que parte do
          que encontramos chegue a outra pessoa.
        </p>
        <p>Professor Emberroot traz as coisas até a mesa.</p>
        <p>
          Arquivista etiqueta tudo, corrige as datas e pergunta por que chegou coberto de lama.
        </p>
        <p>Os gatos contribuem com pelos.</p>
        <p>O acampamento continua.</p>
        <p>
          É aqui que as cartas ficam guardadas antes de aprenderem a viajar. Algumas podem um dia
          sair da tela por completo — dobradas, seladas e enviadas pelo correio. Até lá, elas
          moram aqui: mais lentas do que anúncios, mais quietas do que um feed e endereçadas a
          quem chegou devagar o bastante para lê-las.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro overline="Da mesa" title="Cartas da estrada" />
      <div class="letters-grid">
        {letters.map((letter) => <LetterCard letter={letter} lang="pt" />)}
      </div>
    </div>
  </section>

  <section class="section section--flush-top">
    <div class="container">
      <NewsletterSignup locale="pt" variant="full" />
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro overline="Participação" title="Não é preciso se candidatar" />
      <div class="prose">
        <p>
          A Sociedade não exige, no momento, formulários, referências, exames, uniformes ou
          qualquer papelada competente.
        </p>
        <p>
          Assinar as cartas faz de você uma pessoa correspondente. Fazer parte da Sociedade é
          menos formal e talvez isso já tenha sido concedido sem o seu conhecimento.
        </p>
        <p>
          Sinais comuns incluem atenção desnecessária a pássaros, guardar objetos sem valor
          prático, lembrar de casas abandonadas, escolher o caminho mais longo e desconfiar de que
          o mundo contém mais sentido do que está disposto a explicar.
        </p>
        <p>O único requisito disponível para todo mundo é este:</p>
        <blockquote>Saia. Caminhe mais devagar do que o necessário. Repare em uma coisa que não sirva para nada.</blockquote>
        <p>Você pode relatar suas descobertas à Mesa de Correspondência.</p>
        <p>O Professor Emberroot sugeriu distintivos de participação.</p>
        <p>Arquivista preferiu não comentar.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        overline="O que pode chegar"
        title="Despachos futuros"
        lede="Dependendo do tempo, da tinta, das condições da estrada e do julgamento da Mesa de Correspondência:"
      />
      <ul class="dispatch-list">
        {futureDispatches.map((thing) => <li>{thing}</li>)}
      </ul>
      <p class="dispatch-coda">
        A regularidade não pode ser prometida.<br />A atenção pode.
      </p>
    </div>
  </section>

  <CTASection
    overline="A caixa de correio está aberta"
    title="Escreva para a Mesa de Correspondência"
    text="Perguntas, respostas, observações, desenhos, relatórios de pássaros e descobertas para a Sociedade podem ser enviados à Mesa de Correspondência."
    cta={{ label: 'Escrever para a Mesa de Correspondência', href: mailtoLink('correspondence', 'pt') }}
    secondaryCta={{ label: 'Ver as notas de campo', href: routes.fieldNotes.pt }}
  />
</BaseLayout>

<style>
  .society-intro {
    padding-block: var(--space-block);
  }

  .section--deep {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-block: 1px solid var(--color-line-soft);
  }

  /* Puxa o boletim para perto das cartas a que ele pertence. */
  .section--flush-top {
    padding-top: 0;
  }

  .letters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: 1.2rem;
    max-width: 44rem;
  }

  .dispatch-list {
    max-width: var(--prose-width);
    padding-left: 1.2rem;
    color: var(--color-ink-soft);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dispatch-coda {
    margin-top: var(--space-block);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-ink-soft);
  }
</style>
