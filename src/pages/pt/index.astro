---
/**
 * Início — a entrada do acampamento.
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import ExploreCard from '../../components/sections/ExploreCard.astro';
import CTASection from '../../components/sections/CTASection.astro';
import FieldNoteCard from '../../components/content/FieldNoteCard.astro';
import { routes } from '../../lib/i18n';
import { getFieldNotes } from '../../lib/content';

const latestNotes = (await getFieldNotes('pt')).slice(0, 3);

const exploreCards = [
  {
    roomLabel: 'O arquivo',
    icon: 'notebook' as const,
    title: 'Notas de Campo',
    description:
      'O diário. Notas de estrada, notas de criaturas, boletins do tempo e outras observações, arquivadas com razoável cuidado.',
    href: routes.fieldNotes.pt,
  },
  {
    roomLabel: 'A escrivaninha',
    icon: 'envelope' as const,
    title: 'Correspondência',
    description: 'Cartas da estrada. Algumas coisas chegam melhor dentro de um envelope.',
    href: routes.correspondence.pt,
  },
  {
    roomLabel: 'Uma porta futura',
    icon: 'paw' as const,
    title: 'Sociedade dos Passos Suaves',
    description:
      'Uma sociedade para quem caminha com atenção, atualmente sendo fundada. Inscrições ainda fechadas. A escrivaninha está sendo construída.',
    href: routes.softFootsteps.pt,
  },
  {
    roomLabel: 'A oficina',
    icon: 'tent' as const,
    title: 'Flaneuse Studio',
    description:
      'Sites pequenos com alma, feitos nos fundos do acampamento para artistas, para quem escreve e para outras pessoas sinceras.',
    href: routes.studio.pt,
  },
  {
    roomLabel: 'Quem guarda',
    icon: 'cat' as const,
    title: 'Sobre o Acampamento',
    description: 'A pessoa, o motorhome, os gatos, e por que tudo isso existe.',
    href: routes.about.pt,
  },
];
---

<BaseLayout
  title="Camp Flaneuse"
  description="Camp Flaneuse é um acampamento em movimento para notas de campo, cartas, desenhos, criaturas, vida na estrada e rebeldia mansa — feito de um motorhome chamado Ember, alguns gatos e a crença de que prestar atenção é um jeito de continuar aqui."
  lang="pt"
  translationUrl={routes.home.en}
>
  <Hero
    overline="Um pequeno acampamento na beira da internet"
    title="Camp Flaneuse"
    tagline="Um acampamento em movimento para notas de campo, cartas, rebeldia mansa e assombro."
    intro="Feito de um motorhome chamado Ember, alguns gatos, cadernos demais, e a crença de que prestar atenção é um jeito de continuar aqui. Ele se move. Ele toma notas. Ele deixa uma luz acesa para você."
    primaryCta={{ label: 'Ler as notas de campo', href: routes.fieldNotes.pt }}
    secondaryCta={{ label: 'Visitar o estúdio', href: routes.studio.pt }}
    archiveLine="Arquivo de campo · fundado na estrada · sempre em leve movimento"
  />

  <section class="section">
    <div class="container">
      <SectionIntro
        overline="Que lugar é este?"
        title="Um diário de viagem, um acampamento de artista, um projeto de cartas, um arquivo de campo."
        lede="Camp Flaneuse é o registro da construção de uma vida mais livre — devagar, na estrada, com bichos — e de tudo o que foi reparado pelo caminho: pássaros, rios, estacionamentos estranhos, o tempo, tristezas pequenas, alegrias mais estranhas ainda. Nada aqui é otimizado. Aqui as coisas são reparadas."
      />
      <p class="what-is-more">
        Este é um lugar para as coisas que não cabem direito em nenhum outro: avistamentos de
        pássaros, notas de estrada, cartas, desenhos, boletins do tempo, e a lenta construção de
        uma vida fora do roteiro de sempre.
      </p>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro
        overline="O mapa"
        title="Explore o acampamento"
        lede="O acampamento é pequeno, mas tem cômodos. Cada um coleciona um tipo diferente de coisa."
      />
      <div class="explore-grid">
        {exploreCards.map((card) => <ExploreCard {...card} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro overline="Recém-chegadas da estrada" title="Últimas notas de campo" />
      {latestNotes.length > 0 ? (
        <div class="notes-grid">
          {latestNotes.map((note) => <FieldNoteCard note={note} lang="pt" />)}
        </div>
      ) : (
        <p class="what-is-more">As primeiras notas em português estão a caminho.</p>
      )}
      <p class="all-notes-link">
        <a href={routes.fieldNotes.pt}>Ver o arquivo inteiro →</a>
      </p>
    </div>
  </section>

  <section class="section section--note">
    <div class="container">
      <div class="road-note">
        <p class="label road-note-label">Um bilhete da estrada</p>
        <p class="road-note-body">
          Atualmente em algum ponto entre o calor, os pássaros, os gatos e o próximo lugar para
          estacionar. A chaleira funciona. O toldo tem temperamento. Uma poupa foi avistada na
          terça-feira e tem sido pensada todos os dias desde então.
        </p>
        <p class="road-note-sign">— E.</p>
      </div>
    </div>
  </section>

  <CTASection
    overline="Flaneuse Studio"
    title="Precisa de um site pequeno com alma?"
    text="Nos fundos do acampamento existe um estúdio. Ele faz sites calmos e práticos para artistas e para quem escreve, cria e constrói algo fora do template."
    cta={{ label: 'Visitar o estúdio', href: routes.studio.pt }}
    secondaryCta={{ label: 'Ler a primeira carta', href: `${routes.correspondence.pt}no-001/` }}
  />
</BaseLayout>

<style>
  .section--deep {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-block: 1px solid var(--color-line-soft);
  }

  .what-is-more {
    max-width: 42rem;
    color: var(--color-ink-soft);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.2rem;
  }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.2rem;
  }

  .all-notes-link {
    margin-top: 1.8rem;
    font-weight: 700;
  }

  .section--note {
    padding-block: var(--space-block);
  }

  .road-note {
    max-width: 34rem;
    margin-inline: auto;
    background: var(--color-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
    padding: 1.8rem 2rem;
    transform: rotate(-0.6deg);
  }

  .road-note-label {
    color: var(--color-clay);
    margin-bottom: 0.8rem;
  }

  .road-note-body {
    font-family: var(--font-hand);
    font-size: 1.45rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .road-note-sign {
    margin-top: 0.9rem;
    font-family: var(--font-hand);
    font-size: 1.35rem;
    color: var(--color-ink-soft);
    text-align: right;
  }
</style>
