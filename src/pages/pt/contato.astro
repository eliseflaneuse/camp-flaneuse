---
/**
 * Contato — a caixa de correio do acampamento, organizada em
 * destinos claros. Os endereços vêm de lib/contact.ts; o texto
 * visível mora nesta página.
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import Icon, { type IconName } from '../../components/decor/Icon.astro';
import { routes } from '../../lib/i18n';
import { contactAddresses, mailtoLink } from '../../lib/contact';

const desks: {
  key: 'general' | 'correspondence' | 'studio';
  icon: IconName;
  color: string;
  name: string;
  description: string;
}[] = [
  {
    key: 'general',
    icon: 'tent',
    color: 'var(--color-clay)',
    name: 'Escreva para o acampamento',
    description: 'Para perguntas, recados e mensagens enviadas ao Acampamento Flaneuse.',
  },
  {
    key: 'correspondence',
    icon: 'envelope',
    color: 'var(--color-river)',
    name: 'Mesa de Correspondência',
    description: 'Para cartas, observações, descobertas e respostas destinadas à Sociedade dos Passos Suaves.',
  },
  {
    key: 'studio',
    icon: 'brush',
    color: 'var(--color-olive)',
    name: 'Flaneuse Studio',
    description: 'Para encomendas, colaborações e projetos profissionais.',
  },
];
---

<BaseLayout
  title="Contato"
  description="Escreva para o Camp Flaneuse — o acampamento, a Mesa de Correspondência da Sociedade dos Passos Suaves, ou o Flaneuse Studio para encomendas e colaborações."
  lang="pt"
  translationUrl={routes.contact.en}
>
  <PageTitle
    overline="A caixa de correio"
    title="Escreva para o acampamento"
    lede="O acampamento recebe visitas e cartas. As duas coisas são respondidas — devagar, com sinceridade, por ordem de chegada, se o tempo permitir."
  />

  <section class="section contact-body">
    <div class="container">
      <p class="prose desks-intro">
        Não tem formulário, não tem chatbot, não tem funil. Tem algumas mesas, cada uma com seu
        próprio endereço:
      </p>

      <div class="desks">
        {
          desks.map((desk) => (
            <div class="desk panel" style={`--desk-color: ${desk.color}`}>
              <span class="desk-icon">
                <Icon name={desk.icon} size={22} />
              </span>
              <p class="desk-name">{desk.name}</p>
              <p class="desk-description">{desk.description}</p>
              <a class="desk-email" href={mailtoLink(desk.key, 'pt')}>
                {contactAddresses[desk.key].email}
              </a>

              {desk.key === 'correspondence' && (
                <p class="desk-aside">
                  <span class="desk-aside-icon"><Icon name="notebook" size={15} /></span>
                  O Professor Emberroot também mantém um endereço, para os assuntos mais estranhos da Sociedade:
                  <br />
                  <a href={mailtoLink('professor', 'pt')}>{contactAddresses.professor.email}</a>
                </p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .desks-intro {
    color: var(--color-ink-soft);
  }

  .desks {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.1rem;
    max-width: 64rem;
  }

  .desk {
    padding: 1.5rem 1.6rem;
    border-top: 3px solid var(--desk-color);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .desk-icon {
    display: inline-flex;
    color: var(--desk-color);
    margin-bottom: 0.2rem;
  }

  .desk-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .desk-description {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-email {
    margin-top: 0.4rem;
    font-family: var(--font-label);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  /* Professor Emberroot: um contato menor, relacionado à Mesa. */
  .desk-aside {
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px dashed var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-aside-icon {
    display: inline-flex;
    vertical-align: -2px;
    margin-right: 0.3rem;
    color: var(--color-ink-faint);
  }

  .desk-aside a {
    overflow-wrap: anywhere;
    word-break: normal;
  }
</style>
