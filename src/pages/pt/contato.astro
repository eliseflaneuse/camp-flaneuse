---
/**
 * Contato — a caixa de correio do acampamento, agora aberta de
 * verdade. Três mesas, três endereços.
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import Icon, { type IconName } from '../../components/decor/Icon.astro';
import { routes } from '../../lib/i18n';

const desks: { icon: IconName; color: string; name: string; description: string; email: string }[] = [
  {
    icon: 'tent',
    color: 'var(--color-clay)',
    name: 'Camp Flaneuse',
    description: 'Perguntas, olás, relatórios de pássaros, colaborações e outros esquemas gentis.',
    email: 'hello@campflaneuse.com',
  },
  {
    icon: 'envelope',
    color: 'var(--color-river)',
    name: 'A Mesa de Correspondência',
    description: 'Cartas, respostas e interesse antecipado na Sociedade dos Passos Suaves.',
    email: 'correspondence@campflaneuse.com',
  },
  {
    icon: 'brush',
    color: 'var(--color-olive)',
    name: 'Flaneuse Studio',
    description: 'Projetos de site, grandes ou minúsculos.',
    email: 'studio@campflaneuse.com',
  },
];
---

<BaseLayout
  title="Contato"
  description="Escreva para o Camp Flaneuse — sobre o acampamento, as cartas, a Sociedade dos Passos Suaves, ou um projeto de site para o Flaneuse Studio."
  lang="pt"
  translationUrl={routes.contact.en}
>
  <PageTitle
    overline="A caixa de correio"
    title="Escreva para o acampamento"
    lede="O acampamento recebe visitas e cartas. As duas coisas são respondidas — devagar, com sinceridade, por ordem de chegada, se o tempo permitir."
  />

  <section class="section contact-body">
    <div class="container">
      <p class="prose desks-intro">
        Não tem formulário, não tem chatbot, não tem funil. Tem três mesas, cada uma com seu
        próprio endereço:
      </p>

      <div class="desks">
        {
          desks.map((desk) => (
            <div class="desk panel" style={`--desk-color: ${desk.color}`}>
              <span class="desk-icon">
                <Icon name={desk.icon} size={22} />
              </span>
              <p class="desk-name">{desk.name}</p>
              <p class="desk-description">{desk.description}</p>
              <a class="desk-email" href={`mailto:${desk.email}`}>{desk.email}</a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .desks-intro {
    color: var(--color-ink-soft);
  }

  .desks {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.1rem;
    max-width: 52rem;
  }

  .desk {
    padding: 1.5rem 1.6rem;
    border-top: 3px solid var(--desk-color);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .desk-icon {
    display: inline-flex;
    color: var(--desk-color);
    margin-bottom: 0.2rem;
  }

  .desk-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .desk-description {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .desk-email {
    margin-top: 0.4rem;
    font-family: var(--font-label);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    word-break: break-all;
  }
</style>
