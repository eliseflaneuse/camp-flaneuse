---
/**
 * Contato — a caixa de correio do acampamento.
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import Icon from '../../components/decor/Icon.astro';
import { routes } from '../../lib/i18n';

const topics = [
  'O próprio Camp Flaneuse — perguntas, olás, relatórios de pássaros',
  'Correspondência — cartas, respostas, futuro correio de papel',
  'A Sociedade dos Passos Suaves — interesse antecipado em se inscrever',
  'Flaneuse Studio — projetos de site, grandes ou minúsculos',
  'Colaborações e outros esquemas gentis',
];
---

<BaseLayout
  title="Contato"
  description="Escreva para o Camp Flaneuse — sobre o acampamento, as cartas, a Sociedade dos Passos Suaves, ou um projeto de site para o Flaneuse Studio."
  lang="pt"
  translationUrl={routes.contact.en}
>
  <PageTitle
    overline="A caixa de correio"
    title="Escreva para o acampamento"
    lede="O acampamento recebe visitas e cartas. As duas coisas são respondidas — devagar, com sinceridade, por ordem de chegada, se o tempo permitir."
  />

  <section class="section contact-body">
    <div class="container">
      <div class="prose">
        <p>Você pode escrever sobre:</p>
        <ul>
          {topics.map((topic) => <li>{topic}</li>)}
        </ul>
        <p>
          Não tem formulário, não tem chatbot, não tem funil. Vai ter um endereço de e-mail — de
          verdade — assim que o acampamento terminar de instalar a caixa de correio:
        </p>
      </div>

      <div class="mailbox-closed panel">
        <span class="mailbox-icon"><Icon name="envelope" size={26} /></span>
        <p class="mailbox-line">A caixa de correio ainda não está aberta.</p>
        <p class="email-note label">
          (Um endereço de verdade chega junto com o domínio próprio do acampamento. Até lá, nada
          do que você mandar pode se perder, porque nada pode ser mandado.)
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-body {
    padding-block: var(--space-block) var(--space-section);
  }

  .mailbox-closed {
    margin-top: 2rem;
    max-width: 30rem;
    padding: 1.6rem 1.8rem;
    border-style: dashed;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mailbox-icon {
    display: inline-flex;
    color: var(--color-clay);
  }

  .mailbox-line {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
  }

  .email-note {
    color: var(--color-ink-faint);
  }
</style>
