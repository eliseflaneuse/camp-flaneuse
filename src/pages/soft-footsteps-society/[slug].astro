---
/**
 * Individual letter — a room inside the Society.
 * Designed like a letter, not a blog post: a paper sheet,
 * a dateline, a drawing, a signature.
 */
import { render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ImagePlaceholder from '../../components/content/ImagePlaceholder.astro';
import { detailPaths, formatDate, routes, ui } from '../../lib/i18n';
import {
  findLetterTranslation,
  getLetters,
  slugFromId,
  type Letter,
} from '../../lib/content';

export async function getStaticPaths() {
  const letters = await getLetters('en');
  return letters.map((letter) => ({
    params: { slug: slugFromId(letter.id) },
    props: { letter },
  }));
}

interface Props {
  letter: Letter;
}

const { letter } = Astro.props;
const t = ui.en;
const { Content } = await render(letter);

const translation = await findLetterTranslation(letter, 'pt');
const translationUrl = translation
  ? `${detailPaths.correspondence.pt}${slugFromId(translation.id)}/`
  : undefined;
---

<BaseLayout
  title={letter.data.title}
  description={letter.data.excerpt}
  lang="en"
  translationUrl={translationUrl}
>
  <div class="section letter-wrap">
    <div class="container">
      <article class="letter-sheet panel">
        <header class="letter-head">
          <p class="label letter-number">The Soft Footsteps Society · Nº {letter.data.number}</p>
          <h1>{letter.data.title}</h1>
          {letter.data.subtitle && <p class="letter-subtitle">{letter.data.subtitle}</p>}
          <p class="label letter-dateline">
            {letter.data.location} — {formatDate(letter.data.date, 'en')}
          </p>
        </header>

        <div class="prose letter-body">
          <Content />
        </div>

        {letter.data.drawingPlaceholder && (
          <div class="letter-drawing">
            <ImagePlaceholder lang="en" icon="deer" note="A drawing travels with this letter. It has not arrived yet." />
          </div>
        )}

        {letter.data.enclosure && (
          <aside class="letter-enclosure">
            <p class="label enclosure-label">{t.enclosed}</p>
            <h2 class="enclosure-title">
              <a href={letter.data.enclosure.url}>{letter.data.enclosure.title}</a>
            </h2>
            {letter.data.enclosure.subtitle && (
              <p class="enclosure-subtitle">{letter.data.enclosure.subtitle}</p>
            )}
            <p class="enclosure-link">
              <a href={letter.data.enclosure.url}>{t.readStory} →</a>
            </p>
          </aside>
        )}
      </article>

      <p class="back-link">
        <a href={routes.softFootsteps.en}>← {t.backToCorrespondence}</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .letter-wrap {
    padding-block: var(--space-block) var(--space-section);
  }

  /* The sheet: a paper panel with generous margins, like unfolding
     a letter at a table. */
  .letter-sheet {
    max-width: 46rem;
    margin-inline: auto;
    padding: clamp(2rem, 6vw, 4rem);
    border-top: 3px double var(--color-line);
  }

  .letter-head {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 2.2rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px dashed var(--color-line);
  }

  .letter-number {
    color: var(--color-river);
  }

  .letter-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-ink-soft);
  }

  .letter-dateline {
    margin-top: 0.4rem;
  }

  /* Letters read a touch more like manuscript: serif body. */
  .letter-body {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .letter-drawing {
    margin-top: 2.5rem;
  }

  /* Something folded inside the letter. */
  .letter-enclosure {
    margin-top: 2.5rem;
    padding: 1.5rem 1.7rem;
    border: 1.5px dashed var(--color-line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-paper-deep) 40%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .enclosure-label {
    color: var(--color-forest);
  }

  .enclosure-title {
    font-size: 1.25rem;
  }

  .enclosure-title a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .enclosure-title a:hover {
    color: var(--color-clay-deep);
  }

  .enclosure-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .enclosure-link {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .back-link {
    max-width: 46rem;
    margin: 2rem auto 0;
    font-size: var(--text-sm);
  }
</style>
