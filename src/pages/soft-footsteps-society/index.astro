---
/**
 * The Soft Footsteps Society — the letters room of the camp.
 *
 * Field Notes are things you notice. The Society is things you send.
 * The Correspondence Desk lives here, and the letters live under
 * this route: /soft-footsteps-society/no-001
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import LetterCard from '../../components/content/LetterCard.astro';
import CTASection from '../../components/sections/CTASection.astro';
import NewsletterSignup from '../../components/sections/NewsletterSignup.astro';
import { routes } from '../../lib/i18n';
import { mailtoLink } from '../../lib/contact';
import { getLetters } from '../../lib/content';

const letters = await getLetters('en');

const futureDispatches = [
  'Letters from the road',
  'Small drawings',
  'Ghost stories and other enclosures',
  'Field assignments for the attentive',
  'Seasonal dispatches',
  'Postcards, occasionally urgent',
  'Reports concerning birds, weather, creatures, and other difficult evidence',
];
---

<BaseLayout
  title="The Soft Footsteps Society"
  description="A small, loosely organized society for attentive walkers, slow observers, letter-keepers, and creature-noticers. Home of the Correspondence Desk and the letters from the road."
  lang="en"
  translationUrl={routes.softFootsteps.pt}
>
  <PageTitle
    overline="Sociedade dos Passos Suaves"
    title="The Soft Footsteps Society"
    lede="A small and loosely organized society for attentive walkers, slow observers, letter-keepers, creature-noticers, and people trying to move through the world without making quite so much noise."
  />

  <section class="section society-intro">
    <div class="container">
      <div class="prose">
        <p>
          The Society gathers people who notice, collect, remember, and occasionally send one
          another evidence that the world is still strange, alive, and capable of answering back.
        </p>
        <p>Some observations belong in the Field Archive.</p>
        <p>Others require an envelope.</p>
        <p>
          The Society currently keeps its Correspondence Desk at Camp Flaneuse, a moving camp from
          which letters, drawings, stories, field assignments, and other gentle evidence are sent
          into the world.
        </p>
        <p>
          There is no fixed headquarters. The geography is flexible. Membership begins by noticing
          something and refusing to hurry past it.
        </p>
        <p>
          The Society is still taking shape, but it is no longer merely theoretical.
        </p>
        <p>The first letter has left the desk.</p>
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro
        overline="The room within the room"
        title="The Correspondence Desk"
      />
      <div class="prose desk-prose">
        <p>
          The Correspondence Desk is the part of the Society responsible for making sure some of
          what we find reaches someone else.
        </p>
        <p>Professor Emberroot brings things in.</p>
        <p>
          The Archivist labels them, repairs their dates, and asks why they were delivered covered
          in mud.
        </p>
        <p>The cats contribute hair.</p>
        <p>The camp continues.</p>
        <p>
          This is where letters are kept before they learn how to travel. Some may eventually
          leave the screen entirely — folded, stamped, and sent through the post. Until then, they
          live here: slower than announcements, quieter than a feed, and addressed to whoever has
          arrived softly enough to read them.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro overline="From the desk" title="Letters from the road" />
      <div class="letters-grid">
        {letters.map((letter) => <LetterCard letter={letter} lang="en" />)}
      </div>
    </div>
  </section>

  <section class="section section--flush-top">
    <div class="container">
      <NewsletterSignup locale="en" variant="full" />
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro overline="Membership" title="No application required" />
      <div class="prose">
        <p>
          The Society does not currently require forms, references, examinations, uniforms, or
          competent paperwork of any kind.
        </p>
        <p>
          Subscribing to the letters makes you a correspondent. Membership itself is less formal
          and may already have been granted without your knowledge.
        </p>
        <p>
          Common signs include unnecessary attention to birds, keeping objects with no practical
          value, remembering abandoned houses, taking the longer path, and suspecting that the
          world contains more meaning than it is willing to explain.
        </p>
        <p>The only requirement available to everyone is this:</p>
        <blockquote>Go outside. Walk slower than necessary. Notice one thing that has no use to you.</blockquote>
        <p>You may report your findings to the Correspondence Desk.</p>
        <p>Professor Emberroot has suggested membership badges.</p>
        <p>The Archivist has declined to comment.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        overline="What may arrive"
        title="Future dispatches"
        lede="Depending on weather, ink, road conditions, and the judgment of the Correspondence Desk:"
      />
      <ul class="dispatch-list">
        {futureDispatches.map((thing) => <li>{thing}</li>)}
      </ul>
      <p class="dispatch-coda">
        Regularity cannot be promised.<br />Attention can.
      </p>
    </div>
  </section>

  <CTASection
    overline="The mailbox is open"
    title="Write to the Correspondence Desk"
    text="Questions, replies, observations, drawings, bird reports, and findings for the Society may be sent to the Archivist."
    cta={{ label: 'Write to the Correspondence Desk', href: mailtoLink('correspondence', 'en') }}
    secondaryCta={{ label: 'Browse the field notes', href: routes.fieldNotes.en }}
  />
</BaseLayout>

<style>
  .society-intro {
    padding-block: var(--space-block);
  }

  .section--deep {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-block: 1px solid var(--color-line-soft);
  }

  /* Pull the newsletter up toward the letters it belongs with. */
  .section--flush-top {
    padding-top: 0;
  }

  .desk-prose {
    margin-top: var(--space-block);
  }

  .letters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: 1.2rem;
    max-width: 44rem;
  }

  .dispatch-list {
    max-width: var(--prose-width);
    padding-left: 1.2rem;
    color: var(--color-ink-soft);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dispatch-coda {
    margin-top: var(--space-block);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-ink-soft);
  }
</style>
