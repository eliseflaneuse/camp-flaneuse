---
/**
 * The Soft Footsteps Society — the letters room of the camp.
 *
 * Field Notes are things you notice. The Society is things you send.
 * The Correspondence Desk lives here, and the letters live under
 * this route: /soft-footsteps-society/no-001
 */
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PageTitle from '../../components/sections/PageTitle.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import LetterCard from '../../components/content/LetterCard.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { routes } from '../../lib/i18n';
import { getLetters } from '../../lib/content';

const letters = await getLetters('en');

const futureDispatches = [
  'Letters from the road',
  'Postcards, occasionally urgent',
  'Small drawings',
  'Field assignments — gentle homework for the attentive',
  'Seasonal dispatches',
  'Enrollment, for those who wish to walk softly on purpose',
];
---

<BaseLayout
  title="The Soft Footsteps Society"
  description="A small society for attentive walkers, slow observers, letter-keepers, and creature-noticers. Home of the Correspondence Desk and the letters from the road. Currently being founded."
  lang="en"
  translationUrl={routes.softFootsteps.pt}
>
  <PageTitle
    overline="Sociedade dos Passos Suaves"
    title="The Soft Footsteps Society"
    lede="A small society for attentive walkers, slow observers, letter-keepers, creature-noticers, and people trying to move through the world without making so much noise."
  />

  <section class="section society-intro">
    <div class="container">
      <div class="prose">
        <p>
          The Society began at the correspondence desk of Camp Flaneuse: a place for letters from
          the road, seasonal dispatches, small drawings, field assignments, and other gentle
          evidence that someone, somewhere, is still paying attention.
        </p>
        <p>Some notes belong in the Field Archive. Others need an envelope.</p>
        <p>
          For now, the Society is still being founded. The drawer is nearly empty. The stamps are
          being considered. The deer has not yet approved the seal.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro
        overline="The room within the room"
        title="The Correspondence Desk"
        lede="This is where the letters are kept before they learn how to travel."
      />
      <p class="desk-more">
        One day, some of them may leave the screen entirely — folded, stamped, and sent through
        the post. Until then, they live here: slower than posts, quieter than announcements,
        addressed to whoever has arrived softly enough to read them.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro overline="From the desk" title="Letters from the road" />
      <div class="letters-grid">
        {letters.map((letter) => <LetterCard letter={letter} lang="en" />)}
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container">
      <SectionIntro overline="Membership" title="Enrollment not yet open" />
      <div class="prose">
        <p>
          The desk is being built, and the desk insists on being built well. If you would like to
          be told when the Society opens its doors, you can
          <a href={routes.contact.en}>write to the camp</a> and say so — early letters will be
          answered in order of arrival, weather permitting.
        </p>
        <p>
          In the meantime, the only requirement for future membership is already available to you:
          go outside, walk slower than necessary, and notice one thing that has no use to you.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        overline="What the Society will send"
        title="Future dispatches"
        lede="Planned, promised, or at least sincerely rumored:"
      />
      <ul class="dispatch-list">
        {futureDispatches.map((thing) => <li>{thing}</li>)}
      </ul>
    </div>
  </section>

  <CTASection
    overline="Meanwhile"
    title="The camp receives visitors."
    text="Questions, early enrollment interest, bird reports — the mailbox is open even while the Society is not."
    cta={{ label: 'Write to the camp', href: routes.contact.en }}
    secondaryCta={{ label: 'Browse the field notes', href: routes.fieldNotes.en }}
  />
</BaseLayout>

<style>
  .society-intro {
    padding-block: var(--space-block);
  }

  .section--deep {
    background: color-mix(in srgb, var(--color-paper-deep) 55%, transparent);
    border-block: 1px solid var(--color-line-soft);
  }

  .desk-more {
    max-width: var(--prose-width);
    color: var(--color-ink-soft);
  }

  .letters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: 1.2rem;
    max-width: 44rem;
  }

  .dispatch-list {
    max-width: var(--prose-width);
    padding-left: 1.2rem;
    color: var(--color-ink-soft);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
