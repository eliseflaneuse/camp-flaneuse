---
/**
 * Hero — the camp entrance. Big serif title, one strong tagline,
 * an intro paragraph, and up to two calls to action.
 */
interface Props {
  title: string;
  tagline: string;
  intro?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Small mono line above the title, e.g. "EST. ON THE ROAD". */
  overline?: string;
}

const { title, tagline, intro, primaryCta, secondaryCta, overline } = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    {overline && <p class="label hero-overline">{overline}</p>}
    <h1>{title}</h1>
    <p class="hero-tagline">{tagline}</p>
    {intro && <p class="hero-intro">{intro}</p>}
    {
      (primaryCta || secondaryCta) && (
        <div class="hero-ctas">
          {primaryCta && (
            <a class="button" href={primaryCta.href}>
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a class="button button--quiet" href={secondaryCta.href}>
              {secondaryCta.label}
            </a>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-section);
    border-bottom: 1px solid var(--color-line-soft);
  }

  .hero-inner {
    max-width: 46rem;
  }

  .hero-overline {
    color: var(--color-moss);
    margin-bottom: 1.1rem;
  }

  .hero-tagline {
    margin-top: 1.1rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.2rem, 2.6vw, 1.5rem);
    color: var(--color-ink-soft);
    text-wrap: balance;
  }

  .hero-intro {
    margin-top: 1.3rem;
    max-width: 38rem;
  }

  .hero-ctas {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
</style>
