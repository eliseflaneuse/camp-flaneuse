---
/**
 * Header — camp signpost.
 * Site name, main navigation, language switcher.
 *
 * The nav is a native <details> disclosure: a plain horizontal bar
 * on desktop, and on small screens a compact "Menu" button that
 * expands the links vertically — no JavaScript, keyboard-accessible
 * out of the box.
 */
import LogoMark from '../decor/LogoMark.astro';
import { routes, ui, type Lang } from '../../lib/i18n';

interface Props {
  lang: Lang;
  translationUrl?: string;
}

const { lang, translationUrl } = Astro.props;
const t = ui[lang];
const other: Lang = lang === 'en' ? 'pt' : 'en';
const otherHome = routes.home[other];
const switchUrl = translationUrl ?? otherHome;
const menuLabel = lang === 'pt' ? 'Menu' : 'Menu';

const navItems = [
  { href: routes.fieldNotes[lang], label: t.nav.fieldNotes },
  { href: routes.atlas[lang], label: t.nav.atlas },
  { href: routes.stories[lang], label: t.nav.stories },
  { href: routes.softFootsteps[lang], label: t.nav.softFootsteps },
  { href: routes.studio[lang], label: t.nav.studio },
  { href: routes.about[lang], label: t.nav.about },
  { href: routes.contact[lang], label: t.nav.contact },
];

const currentPath = Astro.url.pathname.replace(/\/?$/, '/');
const isCurrent = (href: string) => currentPath === href || (href !== routes.home[lang] && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={routes.home[lang]}>
      <span class="brand-mark"><LogoMark size={34} /></span>
      <span class="brand-name">Camp Flaneuse</span>
    </a>

    <nav class="site-nav" aria-label={lang === 'pt' ? 'Navegação principal' : 'Main navigation'}>
      <details class="nav-disclosure">
        <summary class="nav-toggle">{menuLabel}</summary>
        <ul class="nav-list">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </nav>

    <div class="lang-switch" aria-label={t.languageSwitch}>
      {lang === 'en' ? (
        <span class="lang-current" aria-current="true" lang="en">EN</span>
      ) : (
        <a href={switchUrl} lang="en">EN</a>
      )}
      <span aria-hidden="true">·</span>
      {lang === 'pt' ? (
        <span class="lang-current" aria-current="true" lang="pt">PT</span>
      ) : (
        <a href={switchUrl} lang="pt">PT</a>
      )}
    </div>
  </div>
</header>

<style>
  /* A camp sign: solid line over a stitch line. */
  .site-header {
    border-bottom: 1px solid var(--color-line);
    background: color-mix(in srgb, var(--color-card) 60%, transparent);
    position: relative;
  }

  .site-header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    border-bottom: 1.5px dashed var(--color-line);
  }

  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.75rem;
    padding-block: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--color-ink);
    margin-right: auto;
  }

  .brand-mark {
    display: inline-flex;
    flex-shrink: 0;
    transition: transform 160ms ease;
  }

  .brand:hover .brand-mark {
    transform: rotate(-3deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark {
      transition: none;
    }
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-list a {
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-ink-soft);
    padding-block: 0.25rem;
  }

  .nav-list a:hover {
    color: var(--color-clay-deep);
  }

  .nav-list a[aria-current='page'] {
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-clay);
  }

  /* The "Menu" toggle is hidden on desktop; the disclosure behaves
     like a plain container there. */
  .nav-toggle {
    display: none;
  }

  @media (min-width: 721px) {
    /* On desktop the disclosure is a plain container: the links are
       always shown, whatever the <details> open state. Two overrides
       cover both engine behaviours — Chrome hides a closed details via
       the ::details-content pseudo, others via the child's display. */
    .nav-disclosure > .nav-list {
      display: flex !important;
    }
    .nav-disclosure::details-content {
      content-visibility: visible !important;
    }
  }

  .lang-switch {
    font-family: var(--font-label);
    font-size: var(--text-label);
    letter-spacing: 0.1em;
    color: var(--color-ink-faint);
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
  }

  .lang-switch a {
    text-decoration: none;
    color: var(--color-ink-soft);
    padding: 0.15rem 0.2rem;
  }

  .lang-switch a:hover {
    color: var(--color-clay-deep);
  }

  .lang-current {
    color: var(--color-ink);
    font-weight: 500;
    border-bottom: 1.5px solid var(--color-moss);
    padding: 0.15rem 0.2rem;
  }

  @media (max-width: 720px) {
    .header-inner {
      justify-content: space-between;
    }
    .brand {
      margin-right: 0;
    }
    .site-nav {
      order: 3;
      width: 100%;
    }

    /* A tappable "Menu ⌄" button that expands the links. */
    .nav-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      cursor: pointer;
      list-style: none;
      font-family: var(--font-label);
      font-size: var(--text-label);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-soft);
      padding: 0.5rem 0;
    }

    .nav-toggle::-webkit-details-marker {
      display: none;
    }

    .nav-toggle::after {
      content: '';
      width: 0.42rem;
      height: 0.42rem;
      border-right: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;
      transform: translateY(-2px) rotate(45deg);
      transition: transform 150ms ease;
    }

    .nav-disclosure[open] .nav-toggle::after {
      transform: translateY(1px) rotate(-135deg);
    }

    .nav-disclosure[open] .nav-toggle {
      color: var(--color-ink);
    }

    .nav-list {
      flex-direction: column;
      gap: 0;
      padding: 0.3rem 0 0.6rem;
    }

    .nav-list a {
      display: block;
      padding-block: 0.55rem;
      font-size: 1rem;
    }

    .nav-list a[aria-current='page'] {
      border-bottom: none;
      color: var(--color-clay-deep);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-toggle::after {
      transition: none;
    }
  }
</style>
