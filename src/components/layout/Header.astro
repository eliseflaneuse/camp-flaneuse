---
/**
 * Header — camp signpost.
 * Site name, main navigation, language switcher.
 * No JavaScript: on small screens the nav simply wraps.
 */
import LogoMark from '../decor/LogoMark.astro';
import { routes, ui, type Lang } from '../../lib/i18n';

interface Props {
  lang: Lang;
  translationUrl?: string;
}

const { lang, translationUrl } = Astro.props;
const t = ui[lang];
const other: Lang = lang === 'en' ? 'pt' : 'en';
const otherHome = routes.home[other];
const switchUrl = translationUrl ?? otherHome;

const navItems = [
  { href: routes.fieldNotes[lang], label: t.nav.fieldNotes },
  { href: routes.atlas[lang], label: t.nav.atlas },
  { href: routes.stories[lang], label: t.nav.stories },
  { href: routes.softFootsteps[lang], label: t.nav.softFootsteps },
  { href: routes.studio[lang], label: t.nav.studio },
  { href: routes.about[lang], label: t.nav.about },
  { href: routes.contact[lang], label: t.nav.contact },
];

const currentPath = Astro.url.pathname.replace(/\/?$/, '/');
const isCurrent = (href: string) => currentPath === href || (href !== routes.home[lang] && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={routes.home[lang]}>
      <span class="brand-mark"><LogoMark size={34} /></span>
      <span class="brand-name">Camp Flaneuse</span>
    </a>

    <nav aria-label={lang === 'pt' ? 'Navegação principal' : 'Main navigation'}>
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="lang-switch" aria-label={t.languageSwitch}>
      {lang === 'en' ? (
        <span class="lang-current" aria-current="true" lang="en">EN</span>
      ) : (
        <a href={switchUrl} lang="en">EN</a>
      )}
      <span aria-hidden="true">·</span>
      {lang === 'pt' ? (
        <span class="lang-current" aria-current="true" lang="pt">PT</span>
      ) : (
        <a href={switchUrl} lang="pt">PT</a>
      )}
    </div>
  </div>
</header>

<style>
  /* A camp sign: solid line over a stitch line. */
  .site-header {
    border-bottom: 1px solid var(--color-line);
    background: color-mix(in srgb, var(--color-card) 60%, transparent);
    position: relative;
  }

  .site-header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    border-bottom: 1.5px dashed var(--color-line);
  }

  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.75rem;
    padding-block: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--color-ink);
    margin-right: auto;
  }

  .brand-mark {
    display: inline-flex;
    flex-shrink: 0;
    transition: transform 160ms ease;
  }

  .brand:hover .brand-mark {
    transform: rotate(-3deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark {
      transition: none;
    }
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.35rem;
    list-style: none;
    padding: 0;
  }

  .nav-list a {
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-ink-soft);
    padding-block: 0.25rem;
  }

  .nav-list a:hover {
    color: var(--color-clay-deep);
  }

  .nav-list a[aria-current='page'] {
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-clay);
  }

  .lang-switch {
    font-family: var(--font-label);
    font-size: var(--text-label);
    letter-spacing: 0.1em;
    color: var(--color-ink-faint);
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
  }

  .lang-switch a {
    text-decoration: none;
    color: var(--color-ink-soft);
    padding: 0.15rem 0.2rem;
  }

  .lang-switch a:hover {
    color: var(--color-clay-deep);
  }

  .lang-current {
    color: var(--color-ink);
    font-weight: 500;
    border-bottom: 1.5px solid var(--color-moss);
    padding: 0.15rem 0.2rem;
  }

  @media (max-width: 720px) {
    .header-inner {
      justify-content: space-between;
    }
    .brand {
      margin-right: 0;
    }
    nav {
      order: 3;
      width: 100%;
    }
    .nav-list {
      gap: 0.25rem 1.1rem;
    }
  }
</style>
