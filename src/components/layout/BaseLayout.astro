---
/**
 * BaseLayout — the outer shell of every page.
 *
 * Handles <head> metadata, fonts, global styles, skip link,
 * header and footer. Pages pass `translationUrl` so the language
 * switcher can point at "the same room, other door"; when a page
 * has no translation it falls back to the other language's home.
 */
import '@fontsource-variable/fraunces';
import '@fontsource-variable/karla';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../../styles/global.css';

import Header from './Header.astro';
import Footer from './Footer.astro';
import { ui, type Lang } from '../../lib/i18n';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  /** URL of this page in the other language, if it exists. */
  translationUrl?: string;
  /** Open Graph image path — placeholder until real art exists. */
  ogImage?: string;
  /** Keep search engines away (404, drafts, utility pages). */
  noindex?: boolean;
}

const {
  title,
  description,
  lang = 'en',
  translationUrl,
  ogImage = '/og-placeholder.svg',
  noindex = false,
} = Astro.props;

const t = ui[lang];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle =
  title === t.siteName ? `${t.siteName} — ${t.tagline}` : `${title} · ${t.siteName}`;

/* hreflang alternates — only when this page has a counterpart in the
   other language. English is the x-default. */
const translationAbs = translationUrl ? new URL(translationUrl, Astro.site) : undefined;
const hreflangEn = lang === 'en' ? canonicalUrl : translationAbs;
const hreflangPt = lang === 'pt' ? canonicalUrl : translationAbs;
---

<!doctype html>
<html lang={lang === 'pt' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <link rel="canonical" href={canonicalUrl} />
    )}
    {!noindex && translationAbs && hreflangEn && hreflangPt && (
      <>
        <link rel="alternate" hreflang="en" href={hreflangEn} />
        <link rel="alternate" hreflang="pt-BR" href={hreflangPt} />
        <link rel="alternate" hreflang="x-default" href={hreflangEn} />
      </>
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {!noindex && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_BR' : 'en_GB'} />
  </head>
  <body>
    <a href="#main" class="skip-link">{t.skipToContent}</a>
    <Header lang={lang} translationUrl={translationUrl} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
