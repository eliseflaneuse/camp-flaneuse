---
/**
 * ImagePlaceholder — a dashed reservation for a drawing or photo
 * that does not exist yet. Includes a small hand-drawn-ish bird
 * so the empty space still has an inhabitant.
 */
import { ui, type Lang } from '../../lib/i18n';

interface Props {
  lang?: Lang;
  kind?: 'drawing' | 'photo';
  /** Override the default note, e.g. "A drawing of the deer will live here." */
  note?: string;
}

const { lang = 'en', kind = 'drawing', note } = Astro.props;
const t = ui[lang];
const text = note ?? (kind === 'photo' ? t.photoPlaceholder : t.drawingPlaceholder);
---

<figure class="image-placeholder" role="img" aria-label={text}>
  <svg viewBox="0 0 48 32" width="48" height="32" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <!-- a small bird, sitting on nothing in particular -->
    <path d="M20 22 C20 15, 27 13, 30 16 C33 12, 39 13, 39 18 C39 23, 32 25, 27 24 L21 26 L24 23" />
    <circle cx="35.5" cy="16.5" r="0.4" fill="currentColor" />
    <path d="M39 18 L44 16.5" />
    <path d="M26 26 L26 29 M29 25 L29.5 29" />
    <path d="M6 29 L42 29" stroke-dasharray="2 3" />
  </svg>
  <figcaption class="label">{text}</figcaption>
</figure>

<style>
  .image-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    padding: 3rem 1.5rem;
    border: 1.5px dashed var(--color-line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-paper-deep) 45%, transparent);
    color: var(--color-ink-faint);
    text-align: center;
  }

  figcaption {
    color: var(--color-ink-faint);
  }
</style>
