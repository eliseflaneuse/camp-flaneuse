---
/**
 * ImagePlaceholder — a dashed reservation for a drawing or photo
 * that does not exist yet. Includes a small hand-drawn-ish bird
 * so the empty space still has an inhabitant.
 */
import Icon, { type IconName } from '../decor/Icon.astro';
import { ui, type Lang } from '../../lib/i18n';

interface Props {
  lang?: Lang;
  kind?: 'drawing' | 'photo';
  /** Override the default note, e.g. "A drawing of the deer will live here." */
  note?: string;
  /** Which small inhabitant keeps the empty space company. */
  icon?: IconName;
}

const { lang = 'en', kind = 'drawing', note, icon = 'bird' } = Astro.props;
const t = ui[lang];
const text = note ?? (kind === 'photo' ? t.photoPlaceholder : t.drawingPlaceholder);
---

<figure class="image-placeholder" role="img" aria-label={text}>
  <Icon name={icon} size={40} />
  <figcaption class="label">{text}</figcaption>
</figure>

<style>
  .image-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    padding: 3rem 1.5rem;
    border: 1.5px dashed var(--color-line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-paper-deep) 45%, transparent);
    color: var(--color-ink-faint);
    text-align: center;
  }

  figcaption {
    color: var(--color-ink-faint);
  }
</style>
