---
/**
 * MetadataLine — small mono field labels, like the stamped
 * header of an archive card: "8 JULY 2026 · SOMEWHERE ON THE ROAD".
 */
interface Props {
  items: (string | undefined)[];
}

const { items } = Astro.props;
const visible = items.filter(Boolean) as string[];
---

<p class="label metadata-line">
  {visible.map((item, i) => (
    <>
      {i > 0 && <span class="sep" aria-hidden="true">·</span>}
      <span>{item}</span>
    </>
  ))}
</p>

<style>
  .metadata-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.6rem;
  }

  .sep {
    color: var(--color-ink-faint);
  }
</style>
