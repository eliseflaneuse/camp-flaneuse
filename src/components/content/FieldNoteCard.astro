---
/**
 * FieldNoteCard — one journal entry as an archive card: a colored
 * category tab on the spine, a small glyph, and a ruled line at
 * the bottom like the edge of an index card.
 */
import { Image } from 'astro:assets';
import MetadataLine from './MetadataLine.astro';
import Icon, { type IconName } from '../decor/Icon.astro';
import { categoryLabels, detailPaths, formatDate, ui, type Lang, type FieldNoteCategory } from '../../lib/i18n';
import { slugFromId, type FieldNote } from '../../lib/content';

interface Props {
  note: FieldNote;
  lang: Lang;
}

const { note, lang } = Astro.props;
const t = ui[lang];
const href = `${detailPaths.fieldNotes[lang]}${slugFromId(note.id)}/`;
const category = categoryLabels[lang][note.data.category];

/* Each drawer of the archive has its own color and glyph. */
const categoryStyle: Record<FieldNoteCategory, { color: string; icon: IconName }> = {
  road: { color: 'var(--color-clay)', icon: 'pin' },
  creature: { color: 'var(--color-river)', icon: 'bird' },
  studio: { color: 'var(--color-olive)', icon: 'notebook' },
  camp: { color: 'var(--color-moss)', icon: 'tent' },
  weather: { color: 'var(--color-ochre)', icon: 'sun' },
  reading: { color: 'var(--color-forest)', icon: 'book' },
  art: { color: 'var(--color-clay-deep)', icon: 'brush' },
};

const { color, icon } = categoryStyle[note.data.category];
---

<article
  class:list={['panel', 'note-card', note.data.coverImage && 'note-card--stamped']}
  style={`--category-color: ${color}`}
>
  {note.data.coverImage && (
    <span class="note-stamp" aria-hidden="true">
      <Image
        src={note.data.coverImage}
        alt=""
        width={160}
        height={160}
        class="note-stamp-img"
      />
    </span>
  )}
  <div class="note-head">
    <span class="note-icon"><Icon name={icon} size={19} /></span>
    <p class="label note-category">{category}</p>
  </div>
  <h3 class="note-title">
    <a href={href}>{note.data.title}</a>
  </h3>
  <MetadataLine items={[formatDate(note.data.date, lang), note.data.location]} />
  <p class="note-excerpt">{note.data.excerpt}</p>
  <p class="note-link" aria-hidden="true">{t.readNote} →</p>
</article>

<style>
  .note-card {
    position: relative;
    padding: 1.5rem 1.6rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    border-left: 4px solid var(--category-color);
    transition: box-shadow 140ms ease, transform 140ms ease;
  }

  .note-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .note-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  /* A little photo stamp in the corner, like on the letters. */
  .note-stamp {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    padding: 0.3rem;
    background: var(--color-card);
    border: 1.5px dashed var(--color-line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
    transform: rotate(2.5deg);
    pointer-events: none; /* clicks pass through to the card link */
  }

  .note-stamp :global(.note-stamp-img) {
    display: block;
    width: 58px;
    height: 58px;
    object-fit: cover;
    border-radius: 2px;
  }

  /* Keep the text from running under the stamp. */
  .note-card--stamped .note-head,
  .note-card--stamped .note-title {
    padding-right: 5rem;
  }

  .note-icon {
    display: inline-flex;
    color: var(--category-color);
  }

  .note-category {
    color: var(--category-color);
    filter: brightness(0.82); /* keep small text readable on paper */
  }

  .note-title {
    font-size: 1.3rem;
    line-height: 1.25;
  }

  /* Whole card is clickable via the stretched title link. */
  .note-title a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .note-title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .note-card:hover .note-title a {
    color: var(--color-clay-deep);
  }

  .note-excerpt {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }

  .note-link {
    margin-top: auto;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--color-line-soft);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-clay-deep);
  }
</style>
