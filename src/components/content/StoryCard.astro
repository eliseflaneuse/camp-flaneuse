---
/**
 * StoryCard — one tale from the campfire. Darker spine than the
 * field cards (stories are told after sunset), a small flame, and
 * the story type as its label.
 */
import MetadataLine from './MetadataLine.astro';
import Icon from '../decor/Icon.astro';
import { detailPaths, formatDate, storyTypeLabels, ui, type Lang } from '../../lib/i18n';
import { slugFromId, type Story } from '../../lib/content';

interface Props {
  story: Story;
  lang: Lang;
}

const { story, lang } = Astro.props;
const t = ui[lang];
const href = `${detailPaths.stories[lang]}${slugFromId(story.id)}/`;
const typeLabel = storyTypeLabels[lang][story.data.storyType];
const partLabel =
  story.data.part !== undefined
    ? lang === 'pt'
      ? `Parte ${story.data.part}`
      : `Part ${story.data.part}`
    : undefined;
---

<article class="panel story-card">
  <div class="story-head">
    <span class="story-icon"><Icon name="fire" size={19} /></span>
    <p class="label story-type">{typeLabel}</p>
    {partLabel && <p class="label story-part">{partLabel}</p>}
  </div>
  <h3 class="story-title">
    <a href={href}>{story.data.title}</a>
  </h3>
  {story.data.subtitle && <p class="story-subtitle">{story.data.subtitle}</p>}
  <MetadataLine items={[formatDate(story.data.date, lang)]} />
  <p class="story-excerpt">{story.data.excerpt}</p>
  <p class="story-link" aria-hidden="true">{t.readStory} →</p>
</article>

<style>
  .story-card {
    position: relative;
    padding: 1.5rem 1.6rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border-left: 4px solid var(--color-forest);
    transition: box-shadow 140ms ease, transform 140ms ease;
  }

  .story-card:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .story-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .story-icon {
    display: inline-flex;
    color: var(--color-clay);
  }

  .story-type {
    color: var(--color-forest);
  }

  .story-part {
    margin-left: auto;
    color: var(--color-ink-faint);
  }

  .story-title {
    font-size: 1.3rem;
    line-height: 1.25;
  }

  .story-title a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .story-title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .story-card:hover .story-title a {
    color: var(--color-clay-deep);
  }

  .story-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  .story-excerpt {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
  }

  .story-link {
    margin-top: auto;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--color-line-soft);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-clay-deep);
  }
</style>
