---
/**
 * Icon — small monoline camp glyphs, drawn in-house, slightly
 * imperfect on purpose. Decorative by default (aria-hidden);
 * pass a `label` when an icon carries meaning.
 */
export type IconName =
  | 'bird'
  | 'cat'
  | 'envelope'
  | 'notebook'
  | 'pin'
  | 'deer'
  | 'tent'
  | 'sun'
  | 'paw'
  | 'book'
  | 'brush'
  | 'fire'
  | 'footstep';

interface Props {
  name: IconName;
  size?: number;
  /** Stroke color; defaults to currentColor so icons inherit text color. */
  color?: string;
  label?: string;
}

const { name, size = 22, color = 'currentColor', label } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke={color}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
  aria-label={label}
>
  {name === 'bird' && (
    <>
      <path d="M4.5 13.5 C4.5 9.5 9 8.2 11 10.2 C12.8 7.4 18 8.2 18 12 C18 15.2 13.4 16.8 9.8 15.8 L6 17.5 L7.6 15" />
      <circle cx="15.2" cy="11" r="0.4" fill={color} stroke="none" />
      <path d="M18 12 L21.5 11" />
      <path d="M10.3 16.4 L10.2 19.5 M12.8 16.2 L13.2 19.3" />
    </>
  )}
  {name === 'cat' && (
    <>
      <path d="M8.2 6.8 L6.8 3.4 L10.2 5" />
      <path d="M15.8 6.8 L17.2 3.4 L13.8 5" />
      <path d="M6.8 10.6 C6.8 6.9 9 5 12 5 C15 5 17.2 6.9 17.2 10.6 C17.2 13.4 15 15 12 15 C9 15 6.8 13.4 6.8 10.6 Z" />
      <path d="M9.4 10.2 C9.9 10.9 10.6 10.9 11.1 10.2" />
      <path d="M12.9 10.2 C13.4 10.9 14.1 10.9 14.6 10.2" />
      <path d="M4.5 20.5 C9.5 16.8 14.5 16.8 19.5 20.5" />
      <path d="M19.5 20.5 C21.6 19.7 21.8 17.6 20.6 16.2" />
    </>
  )}
  {name === 'envelope' && (
    <>
      <rect x="3" y="6" width="18" height="13" rx="1.5" />
      <path d="M3.8 7.2 L12 13.6 L20.2 7.2" />
    </>
  )}
  {name === 'notebook' && (
    <>
      <rect x="6" y="3.5" width="13" height="17" rx="1.5" />
      <path d="M6 7.5 H4 M6 12 H4 M6 16.5 H4" />
      <path d="M9.5 8.5 H16 M9.5 12 H16 M9.5 15.5 H13" />
    </>
  )}
  {name === 'pin' && (
    <>
      <path d="M12 21 C7.5 15.5 5.5 12.6 5.5 9.5 A6.5 6.5 0 1 1 18.5 9.5 C18.5 12.6 16.5 15.5 12 21 Z" />
      <circle cx="12" cy="9.5" r="2.2" />
    </>
  )}
  {name === 'deer' && (
    <>
      <path d="M9 9.5 C9 6.5 6.8 6.2 5.5 3.5 M9 9.5 C8.2 7.2 6.2 7.6 5.8 6" />
      <path d="M15 9.5 C15 6.5 17.2 6.2 18.5 3.5 M15 9.5 C15.8 7.2 17.8 7.6 18.2 6" />
      <path d="M9 9.5 C11 8.6 13 8.6 15 9.5 L13.7 16.5 C13.2 18.8 10.8 18.8 10.3 16.5 Z" />
      <circle cx="10.8" cy="12.2" r="0.4" fill={color} stroke="none" />
      <circle cx="13.2" cy="12.2" r="0.4" fill={color} stroke="none" />
      <path d="M11.4 16.2 C11.8 16.6 12.2 16.6 12.6 16.2" />
    </>
  )}
  {name === 'tent' && (
    <>
      <path d="M12 4 C9.4 9 6.8 14 4.2 19.5 L9.8 19.4 L12 14.8 L14.2 19.4 L19.8 19.5 C17.2 14 14.6 9 12 4 Z" />
      <path d="M12 14.8 L12 19.4" stroke-width="1.3" />
    </>
  )}
  {name === 'sun' && (
    <>
      <circle cx="12" cy="12" r="3.6" />
      <path d="M12 3.5 V5.6 M12 18.4 V20.5 M3.5 12 H5.6 M18.4 12 H20.5 M6 6 L7.5 7.5 M16.5 16.5 L18 18 M18 6 L16.5 7.5 M7.5 16.5 L6 18" />
    </>
  )}
  {name === 'paw' && (
    <>
      <ellipse cx="7.2" cy="8.6" rx="1.6" ry="2" transform="rotate(-18 7.2 8.6)" />
      <ellipse cx="12" cy="7" rx="1.6" ry="2" />
      <ellipse cx="16.8" cy="8.6" rx="1.6" ry="2" transform="rotate(18 16.8 8.6)" />
      <path d="M8.2 15.4 C9 12.8 15 12.8 15.8 15.4 C17.2 17.6 15.6 19.8 12 19.8 C8.4 19.8 6.8 17.6 8.2 15.4 Z" />
    </>
  )}
  {name === 'book' && (
    <>
      <path d="M12 6.2 C10 4.6 7 4.4 4.5 5.4 L4.5 18 C7 17 10 17.2 12 18.6 C14 17.2 17 17 19.5 18 L19.5 5.4 C17 4.4 14 4.6 12 6.2 Z" />
      <path d="M12 6.2 L12 18.6" stroke-width="1.3" />
      <path d="M6.8 8.5 C8 8.2 9.3 8.3 10.3 8.8 M13.7 8.8 C14.7 8.3 16 8.2 17.2 8.5" stroke-width="1.2" />
    </>
  )}
  {name === 'brush' && (
    <>
      <path d="M19.5 4.5 C17 6.6 14.7 8.9 12.6 11.4" />
      <path d="M12.6 11.4 L10.4 13.8" stroke-width="1.9" />
      <path d="M10.4 13.8 C8 13.4 6 15 5.4 17.4 C5.1 18.5 4.7 19.2 4 19.9 C6.8 20.3 9.3 19.7 10.5 18.4 C11.7 17.2 11.8 15.3 10.4 13.8 Z" />
    </>
  )}
  {name === 'footstep' && (
    <>
      <path d="M12 20 C9.5 19 8 16.8 8.3 14 C8.6 11.5 7.6 10 8.3 8.5 C9 7 10.6 6.5 12 6.5 C13.4 6.5 15 7 15.7 8.5 C16.4 10 15.4 11.5 15.7 14 C16 16.8 14.5 19 12 20 Z" />
      <ellipse cx="9.3" cy="5.5" rx="1.15" ry="1.15" fill={color} stroke="none" />
      <ellipse cx="11.1" cy="4.4" rx="1" ry="1" fill={color} stroke="none" />
      <ellipse cx="13" cy="4.1" rx="0.9" ry="0.9" fill={color} stroke="none" />
      <ellipse cx="14.7" cy="4.6" rx="0.8" ry="0.8" fill={color} stroke="none" />
      <ellipse cx="16.1" cy="5.8" rx="0.65" ry="0.65" fill={color} stroke="none" />
    </>
  )}
  {name === 'fire' && (
    <>
      <path d="M12 3.5 C13.5 6 16.5 7.8 16.5 11.5 C16.5 14.5 14.5 16.5 12 16.5 C9.5 16.5 7.5 14.5 7.5 11.5 C7.5 9.8 8.2 8.6 9.2 7.4 C9.4 8.6 10 9.4 11 9.8 C10.6 7.4 11 5.2 12 3.5 Z" />
      <path d="M4.5 20.5 L12 18.2 L19.5 20.5" />
      <path d="M6.5 18.6 L14 21" stroke-width="1.3" />
    </>
  )}
</svg>
